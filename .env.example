APP_ENV=development
PORT=3000

ANTHROPIC_API_KEY=
MODEL_NAME=anthropic:claude-sonnet-4-20250514

DD_API_KEY=
DD_LLMOBS_ENABLED=true
DD_LLMOBS_AGENTLESS_ENABLED=true
DD_LLMOBS_ML_APP=swinedesk
DD_SITE=datadoghq.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Voice (inbound calls). Caller talks to the same agent as SMS; ElevenLabs speaks replies.
VOICE_ENABLED=true
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cjVigY5qzO86Huf0OWal
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# Publicly reachable base URL Twilio fetches generated audio from (no trailing slash).
# Leave blank to derive from the inbound request host.
PUBLIC_BASE_URL=
VOICE_GREETING=Thanks for calling ELM Pork. How can I help you today?

BACKEND_API_URL=
BACKEND_API_TOKEN=

PARTNER_EMAIL=
PARTNER_PHONE=
BROKER_ALERT_PHONE=
# Comma-separated phones that resolve to the internal broker role over SMS
BROKER_SMS_PHONES=
DOCS_EMAIL=docs@elmpork.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

SESSION_TIMEOUT_MINUTES=30
SESSION_MAX_MESSAGES=30
SESSION_CLEANUP_INTERVAL_MINUTES=10
BROKER_ALERT_THROTTLE_MINUTES=30

# Daily broker summary (SMS). Sent once per day at the local time below.
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_HOUR=9
DAILY_SUMMARY_MINUTE=0
DAILY_SUMMARY_TIMEZONE=America/Mexico_City
# Recipient phone; falls back to BROKER_ALERT_PHONE then PARTNER_PHONE if unset.
DAILY_SUMMARY_PHONE=

# Reminders (e.g. "remind me to call JP in 2 minutes"). Fired in-process by SMS.
REMINDER_POLL_SECONDS=30
# Sent reminders are purged from the store after this many days.
REMINDER_RETENTION_DAYS=7

# Broker price offers ("ask JP if he'd take 85"). Pending offers persist here until
# the recipient accepts/counters/declines. Resolved offers are purged on the cleanup loop.
NEGOTIATION_STORE_PATH=.runtime/negotiations.json
